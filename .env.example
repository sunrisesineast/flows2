# Copy this file to .env.local for local dev, or to .env.production on the
# server. Keep your real values in .local/secrets/ — never commit .env files.
#
# Three deployment profiles — pick ONE database block:
#   A) Local dev / droplet self-host  → DATABASE_URL=file:...
#   B) Vercel + Turso                 → TURSO_* (leave DATABASE_URL unset)
#   C) CI                             → DATABASE_URL=file:./ci-build.db (dummy)

# === Auth ===
# Generate with: openssl rand -hex 32
JWT_SECRET=replace-with-strong-random-32-byte-hex-string

# === Cron ===
# Used by /api/calendar/cron — requests must send ?secret=<this> or
# Authorization: Bearer <this>. Generate the same way as JWT_SECRET.
#
# On Vercel: set CRON_SECRET in project env; Vercel Cron auto-sends
# Authorization: Bearer $CRON_SECRET on scheduled invocations (see vercel.json).
CRON_SECRET=replace-with-strong-random-32-byte-hex-string

# === Site URL ===
# Canonical origin for sitemap, JSON-LD, OAuth redirects, and email links.
# Required on Vercel — defaults to https://renttools.io if unset.
# NEXT_PUBLIC_SITE_URL=https://your-project.vercel.app

# === AI / passport extraction ===
# Get a free key at https://aistudio.google.com
GOOGLE_GEMINI_API_KEY=

# Optional: override the Gemini model. Defaults to "gemini-2.5-flash".
# Note: gemini-2.0-flash is DEPRECATED and shuts down 2026-06-01.
# Free tier is generous (1500 req/day, 1M tokens/min). Paid tier is
# ~$0.0002 per passport extraction. https://ai.google.dev/gemini-api/docs/pricing
# GEMINI_MODEL=gemini-2.5-flash

# === Database ===
# The libSQL adapter supports both local SQLite and Turso. Pick one profile.

# --- A) Local dev / droplet self-host (default) ---
DATABASE_URL=file:./data/prod.db

# --- B) Vercel + Turso (or any cloud libSQL) ---
# Unset DATABASE_URL and use these instead. See docs/VERCEL-TURSO.md.
# TURSO_DATABASE_URL=libsql://your-db-<org>.turso.io
# TURSO_AUTH_TOKEN=

# === Google OAuth (optional — enables "Continue with Google" sign-in) ===
# Create credentials at https://console.cloud.google.com/apis/credentials
# - OAuth 2.0 client type: Web application
# - Authorized JavaScript origins: https://your-domain, http://localhost:3000
# - Authorized redirect URIs: https://your-domain/api/auth/google/callback,
#                              http://localhost:3000/api/auth/google/callback
# Scopes used: openid, email, profile (basic, no verification needed)
# Leave all three blank to disable the Google sign-in button entirely.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Same value as GOOGLE_OAUTH_CLIENT_ID; baked into the client bundle
# at build time so the Sign-In button knows whether to render.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# === Error tracking (optional) ===
# Get a DSN at https://sentry.io — Settings → Client Keys (DSN).
# Free tier: 5k errors/month. Leave blank to disable Sentry entirely.
NEXT_PUBLIC_SENTRY_DSN=

# Optional: auth token for uploading source maps (so stack traces show TS, not minified JS).
# Sentry → Settings → Auth Tokens → "Create New Token" with project:releases scope.
SENTRY_AUTH_TOKEN=

# === Transactional email (optional — enables email-verified signup + password reset) ===
# Get a key at https://resend.com and verify your sending domain first.
# Leave blank to disable: the password-reset flow then returns a friendly
# "email not configured" message instead of sending.
RESEND_API_KEY=
# Sender address — must be on a domain verified in your Resend account.
# Defaults to "RentTools <noreply@renttools.io>" when left blank.
EMAIL_FROM=
